UART_TRANSMITIR:
    BTFSS   PIR1, TXIF          
    GOTO    UART_TRANSMITIR     
    MOVWF   TXREG               
    RETURN
BIN_A_BCD:
    MOVWF   NUM_TEMP
    CLRF    CENTENAS
    CLRF    DECENAS
RESTA_100:
    MOVLW   D'100'
    SUBWF   NUM_TEMP, W     
    BTFSS   STATUS, C       
    GOTO    RESTA_10        
    MOVWF   NUM_TEMP        
    INCF    CENTENAS, F
    GOTO    RESTA_100
RESTA_10:
    MOVLW   D'10'
    SUBWF   NUM_TEMP, W
    BTFSS   STATUS, C       
    GOTO    FIN_BCD
    MOVWF   NUM_TEMP
    INCF    DECENAS, F
    GOTO    RESTA_10
FIN_BCD:
    MOVF    NUM_TEMP, W
    MOVWF   UNIDADES
    RETURN
UART_ENVIA_NUMERO:
    CALL    BIN_A_BCD       
    MOVF    CENTENAS, W
    ADDLW   0x30            
    CALL    UART_TRANSMITIR
    MOVF    DECENAS, W
    ADDLW   0x30
    CALL    UART_TRANSMITIR
    MOVF    UNIDADES, W
    ADDLW   0x30
    CALL    UART_TRANSMITIR
    RETURN
UART_ENVIA_ESTADISTICAS:
    MOVLW   'A'
    CALL    UART_TRANSMITIR
    MOVLW   'D'
    CALL    UART_TRANSMITIR
    MOVLW   'C'
    CALL    UART_TRANSMITIR
    MOVLW   ':'
    CALL    UART_TRANSMITIR
    MOVLW   ' '
    CALL    UART_TRANSMITIR
    MOVF    VALOR_ADC, W
    CALL    UART_ENVIA_NUMERO
    MOVLW   ' '
    CALL    UART_TRANSMITIR
    MOVLW   '-'
    CALL    UART_TRANSMITIR
    MOVLW   ' '
    CALL    UART_TRANSMITIR
    
    MOVLW   'R'
    CALL    UART_TRANSMITIR
    MOVLW   ':'
    CALL    UART_TRANSMITIR
    MOVF    CONT_ROJO, W
    CALL    UART_ENVIA_NUMERO
    MOVLW   ' '
    CALL    UART_TRANSMITIR
    
    MOVLW   'V'
    CALL    UART_TRANSMITIR
    MOVLW   ':'
    CALL    UART_TRANSMITIR
    MOVF    CONT_VERDE, W
    CALL    UART_ENVIA_NUMERO
    MOVLW   ' '
    CALL    UART_TRANSMITIR
    
    MOVLW   'A'
    CALL    UART_TRANSMITIR
    MOVLW   ':'
    CALL    UART_TRANSMITIR
    MOVF    CONT_AZUL, W
    CALL    UART_ENVIA_NUMERO
    
    MOVLW   0x0D            
    CALL    UART_TRANSMITIR
    MOVLW   0x0A            
    CALL    UART_TRANSMITIR
    RETURN
